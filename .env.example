# ====== Api Heroica — variables de entorno ======
# Copiar a .env y completar. NUNCA commitear el .env real.

# Servidor
PORT=3001
# OBLIGATORIO en producción: habilita modo prod (sin logs de body, errores genéricos)
NODE_ENV=production

# Base de datos (usuario con permisos mínimos: SELECT/INSERT/UPDATE/DELETE sobre heroica_oficial)
DB_HOST=localhost
DB_PORT=3306
DB_USER=heroica_app
DB_PASSWORD=
DB_DATABASE=heroica_oficial
# Tamaño del pool de conexiones (default 10)
DB_CONNECTION_LIMIT=10

# Autenticación
# Generar con: openssl rand -hex 64  — rotar si hubo exposición
JWT_SECRET=
# Duración del token de sesión (default 24h). Ej: 12h, 8h, 1h
JWT_EXPIRES_IN=24h

# CORS — OBLIGATORIO en producción. Múltiples orígenes separados por coma.
CORS_ORIGIN=https://app.tudominio.com

# Sincronización BD oficial -> prueba
# DB_SYNC_ENABLED: default true (poner false para desactivar el cron).
# DB_SYNC_ON_BOOT: default false (la sync en cada arranque/deploy está desactivada).
# ADVERTENCIA: requiere privilegios DROP/CREATE y copia datos sensibles a la BD de prueba.
# Recomendado a futuro: correrla como script externo con anonimización.
DB_SYNC_ENABLED=true
DB_SYNC_ON_BOOT=false

# Archivos (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Emails (Resend)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_APROBACION=
RRHH_RESPONSABLE_EMAIL=
