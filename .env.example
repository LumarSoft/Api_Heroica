# Puerto del servidor
PORT=3001

# URL de conexión a la base de datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/heroica

# Secret para JWT (cambiar en producción)
JWT_SECRET=tu_secret_super_seguro_aqui_cambiar_en_produccion
